// prisma/schema.prisma
// EcoVert Mada - Version 2.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// ENUMS
// ========================================

enum UserRole {
  admin
  client
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ========================================
// MODULE AUTH & USERS
// ========================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          UserRole  @default(client)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  // Relations
  refreshTokens RefreshToken[]
  orders        Order[]
  cart          Cart?
  energySimulations EnergySimulation[]  // ← AJOUTÉ
  simulationFeedbacks SimulationFeedback[] // ← AJOUTÉ
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)
}

// ========================================
// MODULE CART (PANIER)
// ========================================

model Cart {
  id        String      @id @default(uuid())
  userId    String      @unique
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@map("cart_items")
}

// ========================================
// MODULE PRODUCTS
// ========================================

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  category    String
  image       String?
  stock       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  orderItems  OrderItem[]
  cartItems   CartItem[]

  @@map("products")
}

// ========================================
// MODULE ORDERS
// ========================================

model Order {
  id        String      @id @default(uuid())
  total     Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  paidAt    DateTime?
  shippedAt DateTime?
  deliveredAt DateTime?
  
  // Relations
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  items     OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Float    @map("unit_price")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

// ========================================
// MODULE ENERGY SIMULATOR
// ========================================

model EnergySimulation {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)  // ← Relation avec User
  
  // Données d'entrée
  surface         Float    // Surface disponible en m²
  consommation    Float    // Consommation en kWh/jour
  localisation    String   // Ville/région
  budget          Float?   // Budget estimé (optionnel)
  
  // Résultats calculés
  nbPanneaux      Int      // Nombre de panneaux recommandés
  capaciteBatterie Float   // Capacité batterie en kWh
  puissanceInstallee Float // Puissance installée en kW
  coutEstime      Float    // Coût estimé en Ar
  economieAnnuelle Float   // Économie annuelle estimée en Ar
  retourInvestissement Float // Retour sur investissement en années
  co2Economise    Float    // CO₂ économisé en kg/an
  surfaceUtilisee Float    // Surface utilisée en m²
  productionJournaliere Float // Production journalière en kWh
  productionAnnuelle Int    // Production annuelle en kWh
  autonomie       Int      // Taux d'autonomie en %
  facteurEnsoleillement Float // Facteur selon localisation
  estDansBudget   Boolean  // Dans le budget ou non
  
  // Métadonnées
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations inverses
  feedbacks       SimulationFeedback[] // ← AJOUTÉ pour la relation inverse
  
  @@map("energy_simulations")
}

model EnergyProduct {
  id          String   @id @default(uuid())
  name        String
  description String
  type        String   // 'panneau', 'batterie', 'onduleur', 'kit'
  price       Float
  power       Float?   // Puissance en kW
  capacity    Float?   // Capacité en kWh
  efficiency  Float?   // Efficacité en %
  warranty    Int      // Garantie en années
  image       String?
  inStock     Boolean  @default(true)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("energy_products")
}

model SimulationFeedback {
  id            String   @id @default(uuid())
  simulationId  String
  simulation    EnergySimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade) // ← Relation avec EnergySimulation
  userId        String
  user          User     @relation(fields: [userId], references: [id]) // ← Relation avec User
  rating        Int      // Note de 1 à 5
  comment       String?
  usedForProject Boolean @default(false) // A utilisé pour un vrai projet
  createdAt     DateTime @default(now())
  
  @@map("simulation_feedbacks")
}